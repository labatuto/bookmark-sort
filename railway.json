{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "PUPPETEER_SKIP_DOWNLOAD=true npm install && npm run build"
  },
  "deploy": {
    "startCommand": "node --import tsx src/backend/server.ts",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
